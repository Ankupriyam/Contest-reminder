# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/contestsync

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# CLIST API
CLIST_API_KEY=
CLIST_USERNAME=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Encryption (for storing Google refresh tokens)
ENCRYPTION_KEY=  # 32 bytes hex (64 hex characters)
ENCRYPTION_IV=   # 16 bytes hex (32 hex characters)

# Frontend
FRONTEND_URL=http://localhost:5173

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
